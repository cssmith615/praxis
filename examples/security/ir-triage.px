// ir-triage.px — Security Incident Response: Ingest → Enrich → Score → Route
//
// Full constitutional routing:
//   score >= 9  → OUT.pagerduty (critical) + OUT.jira (P1)
//   score >= 7  → OUT.pagerduty (error)    + OUT.jira (P2)
//   score >= 4  → OUT.jira (P3) only
//   score <  4  → LOG only
//
// Constitutional rules enforced:
//   - AUDIT.start/close bookends every IR program
//   - RECALL.docs before EVAL.risk (no ungrounded scores)
//   - STORE persist=true (survives restarts)
//   - OUT.pagerduty only on score >= 7
//   - ING.threat_intel wrapped in RETRY(attempts=2)
//
// Requires: ANTHROPIC_API_KEY, PAGERDUTY_ROUTING_KEY, JIRA_BASE_URL/EMAIL/API_TOKEN
// Usage:    praxis run ir-triage.px

GOAL:ir_triage

AUDIT.start(label="ir_triage") ->

ING.siem(alert=$raw_alert, format=auto) ->
SET.alert ->

RECALL.docs(query=$alert, k=5, corpus=security_runbooks) ->
SET.context ->

EVAL.risk(
  context=$context,
  environment="Production SaaS — financial data, PCI-DSS scope, AWS us-east-1",
  provider=claude
) ->
SET.risk ->

STORE.incident(key="ir_triage_active", value=$risk, persist=true) ->

IF.$risk >= 9 ->
  PAR(
    OUT.pagerduty(
      summary="[CRITICAL] Active security incident. Score: 9+/10",
      severity=critical,
      dedup_key="ir_triage_critical"
    ),
    OUT.jira(
      project="SEC",
      summary="[P1-CRITICAL] Security incident — critical risk",
      priority="Critical",
      labels="security, incident, critical, auto-triaged"
    )
  )

IF.$risk >= 7 AND $risk < 9 ->
  PAR(
    OUT.pagerduty(
      summary="[HIGH] Security incident detected. Score: 7-8/10",
      severity=error,
      dedup_key="ir_triage_high"
    ),
    OUT.jira(
      project="SEC",
      summary="[P2-HIGH] Security incident — high risk",
      priority="High",
      labels="security, incident, high, auto-triaged"
    )
  )

IF.$risk >= 4 AND $risk < 7 ->
  OUT.jira(
    project="SEC",
    summary="[P3-MEDIUM] Security incident — medium risk",
    priority="Medium",
    labels="security, incident, medium, auto-triaged"
  )

IF.$risk < 4 ->
  LOG.msg(msg="[LOW-SIGNAL] Score below threshold — monitoring only. alert=$alert")

AUDIT.close(label="ir_triage", outcome=ok)
