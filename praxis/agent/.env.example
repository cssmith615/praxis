# Praxis Agent — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather

# ── Recommended ──────────────────────────────────────────────────────────────
# Your Telegram chat id (get it from https://api.telegram.org/bot<TOKEN>/getUpdates)
# Comma-separated for multiple allowed users.
TELEGRAM_CHAT_IDS=123456789

# Trigger word for group chats — only messages starting with this are processed.
# Leave empty for DM-only bots where all messages should be accepted.
AGENT_TRIGGER=

# ── Optional: goal planning with a different provider ─────────────────────────
# OPENAI_API_KEY=sk-...
# GROK_API_KEY=...

# ── Execution mode ────────────────────────────────────────────────────────────
PRAXIS_MODE=prod
